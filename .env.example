# Shared
# Use APP_ENV=production for formal deployment after production safeguards are configured.
APP_ENV=development
TZ=Asia/Shanghai

# Legacy Streamlit app
PJSK_DATA_DIR=
LEGACY_STREAMLIT_ADMIN_PORT=8512
LEGACY_STREAMLIT_USER_PORT=8513

# Backend
SERVER_PORT=8080
# Bind address. Default 127.0.0.1 listens on loopback only; set 0.0.0.0 or ::
# explicitly (literal IP only, no hostname/port) to listen on all interfaces.
SERVER_HOST=127.0.0.1
# Comma-separated CIDRs of reverse proxies allowed to set X-Forwarded-For.
# Empty means no proxy is trusted and forwarding headers are ignored.
# A same-host proxy should only need 127.0.0.1/32,::1/128. Never use /0.
TRUSTED_PROXY_CIDRS=
# Comma-separated exact http(s) origins allowed for credentialed CORS.
# Empty: development/test keep the two local Vite origins; production allows
# no cross-origin access (serve frontend and API from one origin instead).
# Wildcards, null, paths, queries, and credentials are rejected.
CORS_ALLOWED_ORIGINS=
# Full PostgreSQL DSN. Keep credentials out of Git; leave empty when using split backend variables.
DATABASE_URL=
ADMIN_SESSION_TTL=12h
# Set true when the formal site is served over HTTPS.
ADMIN_COOKIE_SECURE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pjsk
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=200

# Frontend
VITE_API_BASE_URL=

# Optional until recovery-email management is used. Configure both together.
# Standard Base64: encryption decodes to exactly 32 bytes; lookup HMAC to at least 32 bytes.
# These keys must be independent from each other and from every verification/session key.
RECOVERY_EMAIL_ENCRYPTION_KEY=
RECOVERY_EMAIL_HMAC_KEY=

# Recovery-email verification delivery. Keep disabled until SMTP is fully configured.
# Standard Base64, at least 32 decoded bytes. Do not reuse either recovery-email key above.
RECOVERY_EMAIL_VERIFICATION_HMAC_KEY=

# Query-code recovery HMAC. Standard Base64, at least 32 decoded bytes.
# Required in production; development/test legacy fallback is temporary.
# Do not reuse any recovery-email key or submit a real value to Git.
QUERY_CODE_RECOVERY_HMAC_KEY=
# disabled: email recovery remains unavailable; smtp: real delivery; fake: APP_ENV=test only.
# smtp requires a complete configuration. TLS modes are tls or starttls only; certificate
# verification remains enabled and TLS 1.2 is the minimum. Username/password are optional
# only as a pair for a controlled unauthenticated internal relay.
RECOVERY_EMAIL_SENDER_MODE=disabled
RECOVERY_EMAIL_SMTP_HOST=
RECOVERY_EMAIL_SMTP_PORT=
RECOVERY_EMAIL_SMTP_USERNAME=
RECOVERY_EMAIL_SMTP_PASSWORD=
RECOVERY_EMAIL_SMTP_FROM=
RECOVERY_EMAIL_SMTP_FROM_NAME=
RECOVERY_EMAIL_SMTP_TLS_MODE=