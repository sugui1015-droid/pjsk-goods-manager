# Default: let Git normalize text files, but do not force a line ending
# unless a specific rule below matches.
* text=auto

# --- Force LF for source/text file types ---
*.go   text eol=lf
*.vue  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# --- Force CRLF for Windows shell scripts ---
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# --- Binary files: never touch line endings ---
*.xlsx  binary
*.xls   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.db    binary
*.sqlite binary
*.sqlite3 binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
